# ============================================================
# Balu LLM API — Environment Configuration
# Copy this file to .env and fill in the values.
# ============================================================

# -----------------------------------------------------------
# LLM backend: "ollama" (local) or "azure_openai"
# -----------------------------------------------------------
LLM_BACKEND=ollama

# -----------------------------------------------------------
# Ollama (used when LLM_BACKEND=ollama)
# -----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=orca-mini

# -----------------------------------------------------------
# Azure OpenAI (used when LLM_BACKEND=azure_openai)
# -----------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# -----------------------------------------------------------
# Security — change this to a strong random value in production
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# -----------------------------------------------------------
API_KEY=your-secret-api-key-here

# -----------------------------------------------------------
# Generation defaults
# -----------------------------------------------------------
MAX_TOKENS=1024
TEMPERATURE=0.7

# -----------------------------------------------------------
# CORS — JSON list of allowed origins.
# Use ["*"] to allow all origins (not recommended in production).
# Example: ["https://app.example.com","https://admin.example.com"]
# -----------------------------------------------------------
CORS_ORIGINS=["*"]

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
